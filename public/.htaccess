# ── Compresie GZIP ────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# ── Cache ─────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|svg|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Rewrite: URL-uri curate pentru paginile prerenderate ──────────
# Site-ul e generat static (vite-react-ssg): fiecare rută are un fișier .html
# (ex. /ciubare/pmpfiber-comfort-200.html). Servim varianta .html pentru URL-ul
# curat, iar pentru orice altă rută cădem pe index.html (rutare client + 404).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical: forțează HTTPS + www → https://www.pmpfiber.ro (un singur URL, bun SEO).
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.pmpfiber.ro%{REQUEST_URI} [L,R=301]

  # Fișierele și folderele existente trec direct.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Dacă există versiunea .html, o servim (URL fără extensie).
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ /$1.html [L]

  # Restul cad pe SPA-ul prerenderat (hidratare + pagina 404).
  RewriteRule ^ /index.html [L]
</IfModule>

# ── Pagina de eroare ──────────────────────────────────────────────
ErrorDocument 404 /index.html
